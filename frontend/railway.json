{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm ci --omit=dev && npx vite build"
  },
  "deploy": {
    "startCommand": "npm install -g serve && serve -s dist -l 3000",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
